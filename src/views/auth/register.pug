extends ../layout

block content
  h1 Registro

  if error
    p.text-danger= error

  form(method="POST", action="/register")
    label Nombre
    input.form-control.mb-2(type="text", name="name", required)

    label Email
    input.form-control.mb-2(type="email", name="email", required)

    label Contrasena
    input.form-control.mb-2(type="password", name="password", required)

    button.btn.btn-success(type="submit") Registrarme